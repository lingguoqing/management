<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.management.mapper.DashboardMapper">

    <!-- 统计用户总数 -->
    <select id="countUsers" resultType="java.lang.Long">
        SELECT COUNT(*) FROM sys_user WHERE deleted = 0
    </select>

    <!-- 统计角色总数 -->
    <select id="countRoles" resultType="java.lang.Long">
        SELECT COUNT(*) FROM sys_role WHERE deleted = 0
    </select>

    <!-- 统计菜单权限总数 -->
    <select id="countPermissions" resultType="java.lang.Long">
        SELECT COUNT(*) FROM sys_permission WHERE deleted = 0
    </select>

    <!-- 统计今日操作日志数量 -->
    <select id="countTodayOperations" resultType="java.lang.Long">
        SELECT COUNT(*) FROM sys_operation_log WHERE DATE(create_time) = CURDATE()
    </select>

</mapper>